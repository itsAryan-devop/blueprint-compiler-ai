# Copy this file to ".env" and paste your own free API keys.
#   Gemini (free): https://aistudio.google.com/app/apikey   (only ~20 requests/day per key)
#   Groq   (free): https://console.groq.com/keys

# List MULTIPLE comma-separated keys per provider: the app rotates through them
# and skips any that hits its daily limit. Pool keys (e.g. from 2-3 free
# accounts) to multiply the free quota.
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2
GROQ_API_KEYS=your-groq-key-1,your-groq-key-2

# A single key per provider also works (used if the *_API_KEYS lines are absent):
# GEMINI_API_KEY=your-gemini-key
# GROQ_API_KEY=your-groq-key
